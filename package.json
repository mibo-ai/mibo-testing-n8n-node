{
  "name": "n8n-nodes-mibo-testing",
  "version": "0.2.0",
  "description": "n8n community node for Mibo Testing - Capture and send workflow traces for semantic and procedural testing",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/mibo-testing/n8n-nodes-mibo-testing",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "workflow",
    "testing",
    "trace",
    "mibo"
  ],
  "author": {
    "name": "Mibo Testing",
    "email": "support@mibo-testing.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mibo-testing/n8n-nodes-mibo-testing.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "scripts": {
    "build": "tsc && pnpm run copy:icons",
    "copy:icons": "node scripts/copy-icons.mjs",
    "watch": "tsc --watch",
    "lint": "eslint nodes credentials",
    "lint:fix": "eslint nodes credentials --fix",
    "format": "prettier --write \"nodes/**/*.ts\" \"credentials/**/*.ts\" && eslint nodes credentials --fix",
    "format:check": "prettier --check \"nodes/**/*.ts\" \"credentials/**/*.ts\" && eslint nodes credentials",
    "prepublishOnly": "pnpm run build",
    "------- DEV -------": "echo 'Development commands'",
    "dev": "node scripts/dev.mjs",
    "dev:docker": "node scripts/dev-docker.mjs",
    "dev:link": "pnpm run build && pnpm link",
    "------- PROD -------": "echo 'Production commands'",
    "docker:build": "docker build -t n8n-mibo-testing:latest .",
    "docker:run": "docker compose up -d",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MiboTestingApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MiboTesting/MiboTesting.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "chokidar": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.4.0",
    "n8n-workflow": "*",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
